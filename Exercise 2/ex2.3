clear all
close all

% Διαβάζουμε το αρχείο ήχου
[x, Fs] = audioread('recordingX.wav');
% sound(x, Fs)  % Ακούμε το αρχικό σήμα (προαιρετικό)

% Downsampling by 2
x2 = x(1:2:end);
% Downsampling by 4
x4 = x(1:4:end);

% Υπολογισμός DFT
%X = abs(fft(x, Fs));
%X2 = abs(fft(x2, Fs));  % Σωστό Fs για το downsampled σήμα
%X4 = abs(fft(x4, Fs));  % Σωστό Fs για το downsampled σήμα


% Υπολογισμός DFT
X = abs(fft(x, Fs));
X2 = abs(fft(x2, Fs/2));  % Σωστό Fs για το downsampled σήμα
X4 = abs(fft(x4, Fs/4));  % Σωστό Fs για το downsampled σήμα

% Σχεδίαση σημάτων και φασμάτων
figure;

% Σχεδίαση των σημάτων στον χρόνο
subplot(2,3,1), stem(x(1:80)), title('Αρχικό σήμα (80 δείγματα)');
subplot(2,3,2), stem(x2(1:40)), title('Downsampled by 2 (40 δείγματα)');
subplot(2,3,3), stem(x4(1:20)), title('Downsampled by 4 (20 δείγματα)');

% Σχεδίαση των φασμάτων
subplot(2,3,4), plot(X), title('Φάσμα αρχικού σήματος');
subplot(2,3,5), plot(X2), title('Φάσμα downsampled by 2');
subplot(2,3,6), plot(X4), title('Φάσμα downsampled by 4');

% Πληροφορίες αρχείου ήχου
info = audioinfo('recordingX.wav');
disp(info);

